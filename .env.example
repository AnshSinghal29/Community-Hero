# Community Hero — Environment Variables (FREE TIER)
# Only ONE key needed: your free Anthropic API key

# ===========================
# Anthropic API (FREE TIER)
# ===========================
# Get your free key at: https://console.anthropic.com/
# Free tier: 100K tokens/month (~50 reports/day)
ANTHROPIC_API_KEY=sk-ant-v0-...your-free-key-here...

# ===========================
# Local Storage (FREE)
# ===========================
# Images save here (auto-created on first run)
UPLOAD_FOLDER=./uploads

# SQLite database path (auto-created on first run)
DATABASE_PATH=./issues.db

# ===========================
# Flask Settings
# ===========================
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_PORT=5000

# ===========================
# NO LONGER NEEDED (removed)
# ===========================
# GOOGLE_SHEETS_ID        — replaced by SQLite
# GOOGLE_MAPS_API_KEY     — replaced by Leaflet/OpenStreetMap
# GOOGLE_APPLICATION_CREDENTIALS — no longer needed
# service_account.json    — no longer needed
